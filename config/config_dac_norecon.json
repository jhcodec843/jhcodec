        "gradient_accumulation_steps": 1,
        "num_workers": 4,
        "use_phaseaug": true,
        "init_dataset": false,
        "profile": false,
        "verbose_grad_norm": false,
        "verbose_norm_threshold_max": 5.0,
        "verbose_norm_threshold_min": 0.001,
        "verbose_paramter_norm": false,
        "use_discriminator": true,
        "encoder_checkpoint": null,
